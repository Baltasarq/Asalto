! [loc#16]
CuevaConLuz PASAJE_DEL_AGUA "Pasaje del agua"
with
	description [;
        print "^Como un acueducto, el agua baja con gran fuerza de norte a este,
                aunque la salida practicable es la del oeste. Altas y desnudas rocas,
                elevadas sobre el lago de entrada, permiten observar la gran galería
                en la que te sumergiste.
                ^^"
        ;

        if ( self hasnt visited ) {
            novelar(
                "Desde su puesto, Ulfius pudo observar sin ser visto a los sajones
                 merodeando alrededor del lago, a gran distancia.
                 Era obvio que le buscaban, aunque
                 desde luego, no le encontrarían. La fuerte y profunda corriente
                 de agua garantizaba que, aunque le vieran, cosa que no iba a ocurrir,
                 no podrían capturarle. En realidad, ni siquiera gritando podrían
                 advertir su presencia, debido al fuerte sonido del agua.
                "
            );
        }

		rtrue;
	],
	w_to PASAJE_ARENOSO,
;

SceneryThing LAGO4 "lago" PASAJE_DEL_AGUA
with
    name 'gran' 'lago',
    name_f 'agua' 'cristalina',
    name_fp 'aguas' 'cristalinas',
    description [;
        print GRAN_LAGO.desc, "^";
        rtrue;
    ],
    react_before [;
        Gritar:
            player.think( "Está bien, si me quieren, me tendrán." );
            novelar( "Desenvainando su espada, el britano se preparó para la lucha." );
            player.say( "ˇˇˇEEEHHHH!!!" );
            novelar( "El britano no observó cambio alguno en los sajones,
                     al menos que fuera apreciable, allá en la distancia. "
            );
            rtrue;
    ],
;

