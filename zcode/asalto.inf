! [loc#47]
CuevaConLuz SALIDA_DE_LA_CUEVA "Salida de la cueva"
with
	description [;
        print "^^Una puerta impide la salida de la cueva, ya se adivina la luz diurna al otro lado.^";
		rtrue;
	],
	n_to CRUCE_DE_PASAJES,
    s_to [;
        if ( objPUERTA hasnt locked ) {
            novelar( "Ulfius hizo girar la llave, con manos casi temblorosas. Esta giró,
                      y, al ser liberada de la presión del cerrojo, la hinchada puerta
                      cedió en sus goznes hacia sí, inundando la estancia de una
                      gran claridad."
            );

            if ( isReachable( objANTORCHA ) ) {
                move objANTORCHA to location;

                novelar( "Ulfius apagó y tiró a un lado la antorcha, agradecido
                          de no tener que utilizarla más."
                );
            }

            playerTo( BOSQUE_A_LA_ENTRADA, 2 );
        } else {
            if ( objLlave in player ) {
                <<Open objPuerta>>;
            }

            player.think( "La puerta bloquea la salida de la cueva." );
        }
    ],
;

