! [loc#18]
CuevaConLuz PUENTE_DE_PIEDRA "Puente de piedra"
with
	description [;
        print "^Un arco de piedra se eleva, cual puente sobre la oscuridad, de este a oeste.
                El arco, de basta manufactura, parece llevar siglos en su sitio, si bien
                es obvio que esto es imposible. El musgo cuelga de los laterales del puente,
                dejando resbalar humedad y gotas por sus ramajes.
                En la mitad del arco, en su punto más alto, un altar se eleva
                un par de pies sobre los sillares.^^";
		rtrue;
	],
	e_to RECODO_DEL_CANAL,
	w_to ESTALACTITAS,
;

