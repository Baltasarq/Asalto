with
	name 'CAPA',
	description "Tu capa, de fina lana tintada de negro, que te distingue como oficial al mando en las batallas. Bueno, es una de las cosas, al menos.",
    before [;
        Cut, Attack:
            destroyCapa();
            "Rasgas la capa como buenamente puedes, tratando de obtener el
             mayor número de trozos, de un cierto tamańo.";
        Tie:
            if ( second == puentePodrido ) {
                "La capa es demasiado grande e inmanejable para atarla al cordaje.";
            }
    ],
has female clothing worn;

