    ],
;

SceneryThing objMESA "mesa" HOGAR_DE_AMBROSIO
with
    name 'mesa',
    description "Un tanto destartalada.",
has transparent supporter female;

SceneryThing objVELAS "mesa" objMESA
with
    name_fp 'velas',
    name_mp 'candeleros',
    name_m  'sebo',
    description "Casi ya reducidas a cabos, tiemblan encima de la mesa, goteando
                 sebo done ya ha goteado antes miles de veces, sin haberse
                 limpiado nunca.",
has female pluralname;

