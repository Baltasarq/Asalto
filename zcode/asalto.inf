! [loc#31]
Room PUERTA_BLOQUEADA "Puerta bloqueada"
with
	description [;
        if ( objROCASPUERTA.estaBloqueando() ) {
            print "^^En otros tiempos, era una puerta.
                     Ahora, el pasaje se encuentra bloqueado
                    por grandes rocas entre las columnas de un arco de medio punto.
                    Es posible volver al sur.^"
            ;
            rtrue;
        } else {
            print "Un maltrecho arco con sus columnas y dintel se sitúa en medio
                   del pasaje, de norte a sur. Multitud de rocas yacen desparramadas
                   por el suelo del pasaje.";
            rtrue;
        }
	],
	s_to ESTRECHO_PASAJE,
	e_to PRECIPICIO,
    n_to [;
        if ( objROCASPUERTA.estaBloqueando() ) {
            player.think( "ˇNecesito echar abajo esas rocas para poder pasar!" );
            rtrue;
        }

        playerTo( PRECIPICIO, 2 );
        rtrue;
    ],
;

SceneryThing objROCASPUERTA "puerta bloqueada" PUERTA_BLOQUEADA
private
    bloqueando true,
with
    estaBloqueando [;
        return self.bloqueando;
    ],
    desbloquea [;
        novelar( "Empujando con fuerza, y, tras diversas intentonas,
                         las rocas cayeron hacia adelante, levantando una nube
                         de polvo alrededor de Ulfius. Apartando el polvo con
                         las manos, Ulfius tosió brevemente, observando el
                         pasaje creado."
        );
        self.bloqueando = false;

        rtrue;
    ],
    name_f 'puerta' 'bloqueada' 'columna',
    name_fp 'rocas' 'columnas',
    description [;
        if ( self.estaBloqueando() ) {
            print "Las rocas bloquean la puerta, desordenadamente
                   y con grandes huecos entre ellas...^";
        }
        <<look>>;
    ],
    before [;
        Attack, Push:
            if ( second ~= Nothing
              && second ~= objTRONCO )
            {
                player.think( "No podré hacerlo con eso." );
                rtrue;
            }

            if ( ~~( isReachable( objTRONCO ) ) ) {
                player.think( "Necesito algo fuerte, estrecho en la punta,
                               con lo que hacer palanca." );
                rtrue;
            }

            if ( ~~( objTRONCO.estaAfilado() ) ) {
                player.think( "La punta es demasiado ancha...
                               ˇNo consigo meterlo en ningún hueco!"
                );
                rtrue;
            }

            return self.desbloquea();
    ],
;

! [loc#16]
CuevaConLuz RECODO_DE_LA_CUEVA "Recodo de la cueva"
with
	description [;
        print "^La iridiscente cueva gira de este a sur, en una suerte de túnel en
                semipenumbra. Un puente lleno de podedumbre une ambas orillas del lecho
                de un salvaje río. Puedes ver un montículo.^^";
		rtrue;
	],
	s_to PASAJE_ARENOSO,
	e_to [;
        if ( puentePodrido.atraviesalo() ) {
            playerTo( PUENTE_SEMIPODRIDO, 2 );
            rtrue;
         }
         rtrue;
    ],
;

SceneryThing monticuloDeFango "montículo de fango" RECODO_DE_LA_CUEVA
with
    name 'monticulo' 'fango',
    description "Es un montículo de fango maloliente. Curioso...",
has supporter;

! [loc#19]
CuevaConLuz RECODO_DEL_CANAL "Recodo del canal"
with
	description [;
        print "^La estancia arenosa contempla el paso del canal, de norte a este.
                El agua ruge más que fluye ahora, causando gran estruendo en la
                estancia.
                Al este, donde una pared cierra el paso y el canal de agua prosigue por
                una suerte de túnel, puedes ver una especie de refugio.
                Cuidadosamente construido
                con piedras y barro, aprovechando la pared del fondo de puedra,
                es de factura similar al puente.^^";
		rtrue;
	],
	w_to PUENTE_DE_PIEDRA,
    e_to REFUGIO_DE_AMBROSIO,
    in_to REFUGIO_DE_AMBROSIO,
;

SceneryThing canal "canal de agua" RECODO_DEL_CANAL
with
    name 'pasaje' 'canal' 'agua' 'torrente' 'rio',
    description "El canal de agua baja hacia el este con inusitado brío,
                 golpeando las rocas que hacen de diques para el torrente.",
    react_before [;
        ThrowAt, Drop:
            if ( ALBERGUE_DE_REFUGIADOS hasnt visited ) {
                novelar( "Ulfius sintió el irrefrenable deseo de lanzar cosas
                          al torrente de agua, entreteniéndose con la visión
                          del agua arrastrándolas."
                );
                player.think( "No deseo perder nada en la fuerza de ese torrente." );

                if ( noun == objESPADA ) {
                    novelar(
                        "El britano agarró con fuerza la empuńadura de su espada,
                         mientras múltiples recuerdos inundaban su mente a
                         borbotones."
                    );
                    player.think(
                        "No, no. Es todo lo que me queda de mi padre.
                         No la arriesgaré inútilmente."
                    );
                }

                rtrue;
            }

            if ( second == self
              || second == Nothing )
            {
                move noun to INTERIOR_DE_LA_CASCADA;
                print "Tiras ", (the) noun, " al canal, de manera que se pierde
                      rápidamente en la oscuridad de la cueva, arrastrado por la
                      increíble fuerza del agua.^";
                rtrue;
            }
    ],
;

CuevaConLuz REFUGIO_DE_AMBROSIO "Refugio"
private
    ancianoDesaparecido true,
with
    description [;
        print "El refugio es muy confortable en su interior. Puedes distinguir
               varios estantes con objetos cotidianos, además de un pequeńo,
               aunque cómodo catre.^";

        if ( pnjAMBROSIO.getStatus() > 1
          && self.ancianoDesaparecido )
        {
            player.think( "El anciano... ˇha desaparecido!... un momento...
                           żCómo es que sabía mi nombre?"
            );
            self.ancianoDesaparecido = false;
        }

        rtrue;
    ],
    out_to RECODO_DEL_CANAL,
    w_to RECODO_DEL_CANAL,
;

SceneryThing objCATRE2 "catre" REFUGIO_DE_AMBROSIO
with
    name_m 'catre' 'lecho' 'sobre',
    name_f 'cama' 'paja',
    description "Una manta cubre varios fardos de paja. Está seco y parece muy
                confortable.",
    before [;
        Enter:
            <<Sleep>>;
    ],
    react_before [;
        Sleep:
            if ( pnjAMBROSIO in location ) {
                player.think( "Estoy muy cansado, pero sería de mala educación
                               dormir en el catre de otro... ˇdelante de sus narices!"
                );
                rtrue;
            }

            novelar( "Aunque hasta ahora la excitación no le habían dejado dormir,
                   el cansancio venció al britano, ante tan tentadora visión.
                   Se recostó en el catre, y trató de descansar, cayendo en un
                   pesado sueńo sin esfuerzo."
            );

            novelar( "Sin embargo, el sueńo
                   no fue reparador, y al despertar sólo se encuentró levemente
                   más descansado.^"
            );
            rtrue;
    ],
;

SceneryThing objOBJETOS_REFUGIO "objetos cotidianos" REFUGIO_DE_AMBROSIO
with
    name_mp 'objetos' ' cotidianos',
    name_m 'objeto' 'cotidiano',
    name_f 'estanteria' 'balda',
    name_fp 'estanterias' 'baldas',
    description "Menudencias cotidianas sin importancia.",
    before [;
        Examine:
            rfalse;
        default:
            player.think( "En verdad que estos utensilios no tienen
                           ni la más mínima utilidad para mi."
            );
    ],
;


SceneryThing refugioFalso "refugio"
with
    found_in [;
        if ( location == RECODO_DEL_CANAL or REFUGIO_DE_AMBROSIO )
                rtrue;
        else    rfalse;
    ],
    name 'refugio',
    name_f 'cabana' 'casa',
    description [;
        <<look>>;
    ],
    before [;
        Enter:
            if ( location == RECODO_DEL_CANAL ) {
                <<go e_obj>>;
            }
        GetOff:
            if ( location == REFUGIO_DE_AMBROSIO ) {
                <<go w_obj>>;
            }

    ],
;

