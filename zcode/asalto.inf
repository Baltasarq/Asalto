SceneryThing objALTAR "altar" PUENTE_DE_PIEDRA
with
	name 'ALTAR',
	description "Justo en la mitad del puente, su objetivo es sustentar algo importante."
has  supporter ;

SceneryThing objAMBROSIO "ambrosio" RECODO_DEL_CANAL
with
	name 'AMBROSIO',
	description "Ambrosio es un hombre de mediana edad, que te mira afable."
has   ;

Thing objANTORCHA "antorcha apagada" limbo
with
    short_name "antorcha apagada",
	name 'ANTORCHA',
	description [;
        print "La antorcha ";
        if ( self has light )
                "alumbra, proporcionando una llama cálida y segura.";
        else    "está apagada.";

        "^";
    ],
    lightTorch [;
        if ( self has light ) {
            return self.yaEncendida();
        };

        give self light;
        self.short_name = "antorcha";
        rtrue;
    ],
    yaEncendida [;
        player.think( "ˇPero si ya está encendida!" );
        rtrue;
    ],
    before [;
        Burn:
            if ( self has light ) {
                return self.yaEncendida();
            }
            player.think( "La única forma de hacerlo es utilizar el pedernal." );
            rtrue;
    ],
has female ;

