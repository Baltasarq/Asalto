has   ;

Thing objLLAVE "llave" objMesa
with
	name 'LLAVE',
	description "Una llave de hierro, muy oxidada, ciertamente.",
    before [;
        Take:
            if ( self in objMesa
              && pnjAmbrosio.getStatus() < 3 )
            {
                novelar( "El britano trató de coger la llave, pero Ambrosio
                          la atrajo hacia sí, lanzándole una mirada expectante."
                );
                rtrue;
            }
        Rub:
            <<Rub objPUERTA>>;
    ],
has female  ;

Thing objPEDERNAL "pedernal" limbo
with
	name 'PEDERNAL',
	description "Se trata de una dura piedra.",
    before [;
        Attack:
            if ( second ~= Nothing
              && second ~= objESPADA )
            {
                player.think( "Eso no tiene demasiado sentido." );
            }

            if ( objESPADA in player ) {
                if ( isReachable( objANTORCHA ) ) {
                    novelar( "Utilizando la espada, Ulfius golpeó con fuerza
                              el pedernal, encendiendo la antorcha."
                    );

                    move objANTORCHA to location;
                    return objANTORCHA.lightTorch();
                } else {
                    if ( objANTORCHA has light ) {
                        player.think( "Mmm... ya está encendida." );
                        rtrue;
                    }

                    print "Utilizando la espada, golpeas el pedernal, con lo que poderosas
                          chispas saltan en todas direcciones.^";
                    rtrue;
                }
            }
    ],
has   ;

Thing objPIEDRA "piedra" objALTAR
with
	name 'PIEDRA',
	description "Recia y pesada, pero no muy grande. Parece representar a una mujer,
                 como regordeta, de desproporcionados pechos."
has female  ;

SceneryThing objPUERTA "puerta" SALIDA_DE_LA_CUEVA
private
    oxidado true,
with
	name_f 'PUERTA' 'cerradura',
    name_m 'candado' 'cerrojo',
	description "Muy recia y con un gran candado; un poco oxidado, pese a su apariencia.",
    with_key objLLAVE,
    estaOxidado [;
        return self.oxidado;
    ],
    ponNoEstaOxidado [;
        self.oxidado = false;
    ],
    after [;
        <<go s_obj>>;
    ],
    before [;
        Open, Unlock:
            if ( ~~isReachable( objLLAVE ) ) {
                "Será necesaria la llave, primero, para quitar el cerrojo.";
            }

            if ( self.estaOxidado() ) {
                novelar( "Ulfius trató con todas sus fuerzas de hacer girar
                          la llave, pero el cerrojo no respondía a sus
                          esfuerzos."
                );

                rtrue;
            }

            <<Go s_obj>>;
        Rub:
            if ( second == Nothing ) {
                second = player.getTrapoAceitoso();
            }

            if ( second ~= Nothing
              || ~~( second ofclass ThingMadeOfCloth ) )
            {
                "Necesitas algo apropiado con lo que aceitar puerta y llave.";
            }

            if ( ~~second.estaAceitoso() ) {
                "Es necesario que el trapo tenga algo que permita engrasar.";
            }

            novelar( "Ulfius paso el trapo con cuidado por el cerrojo, tratando
                      de que el máximo de aceite de coco cayera por el ojo de la
                      cerradura. Después, exprimiendo el trapo, froto con fuerza
                      la llave, de manera que todo quedase en las mejores
                      condiciones." );

            self.ponNoEstaOxidado();
            rtrue;
    ],
has female openable lockable locked;

SceneryThing objCOCO "coco" REFECTORIO_DE_REFUGIADOS
with
    name 'coco',
    description [;
        "Pues sí, uno de esos cocos peludos. Es curioso, no pensabas que nadie
         pudiera tener uno por estos lugares.";
    ],
    before [;
        Attack:
            move self to limbo;
            move objPULPA to jugador;

            novelar( "Ulfius rompió el coco, quedando la pulpa al descubierto.
                      El britano quedó mojado de leche de coco."
            );

            rtrue;
    ],
;

SceneryThing objPULPA "pulpa de coco" limbo
with
    name 'coco',
    description [;
        "La tierna y aceitosa pulpa de lo que antes era el coco.";
    ],
    before [;
        Tie, Rub:
            if ( second == Nothing ) {
                "Necesitas atar el coco a algo.";
            }

            if ( ~~( second ofclass ThingMadeOfCloth ) ) {
                "No puedes hacerlo con eso.";
            }

            if ( children( second ) > 0 ) {
                "Ya tiene atadas cosas.";
            }

            novelar( "Ulfius ató y enrolló mil veces la pulpa en el trozo de lo
                      que antes fue su capa, haciendo que la pulpa se deshiciera,
                      aceitando la tela."
            );

            second.ponAceitoso();
            rtrue;
    ],
;

SceneryThing objSERPIENTE "serpiente" PASAJE_DE_LA_SERPIENTE
with
	name 'SERPIENTE',
	description "Una serpiente bloquea el paso. Entre el agua y el animal, nada se puede hacer."
has   ;

Thing objTRONCO "tronco" PASAJE_ARENOSO
private
    afilado false,
with
    estaAfilado [;
        return self.afilado;
    ],
    afilar [;
        if ( second ~= Nothing
          && second ~= objESPADA
          && second ~= objPEDERNAL )
        {
            player.think( "No creo que pueda afilarlo con eso." );
            rtrue;
        }

        if ( second == Nothing ) {
            if ( isReachable( objESPADA ) ) {
                second = objESPADA;
            }
            else
            if ( isReachable( objPEDERNAL ) ) {
                second = objPEDERNAL;
            }
            else {
                print "No tienes nada con que afilarlo.^";
                rtrue;
            }
        }

        if ( ~~( isReachable( self ) ) ) {
            print (The) self, " no está aquí.^";
            rtrue;
        }

        if (~~( isReachable( objESPADA ) ) ) {
            print (The) objESPADA, " no está aquí, y así no se puede afilar nada.^";
            rtrue;
        }

        if ( self.estaAfilado() ) {
            player.think( "Mmm... está afilado ya. No tiene sentido insistir." );
            rtrue;
        }

        self.afilado = true;
        "Afilas con mańa ", (the) self, " con ", (the) second, ", hasta estar satisfecho con el filo.";
    ],
	name 'TRONCO',
	description [;
        print "Es un trono recio, pero de liviano peso.";

        if ( self.estaAfilado() ) {
            print " La punta ha sido afilada hasta formar casi una pica.";
        }

        "^";
    ],
    before [;
        Sharpen, Attack:
            return self.afilar();
    ],
has   ;

ThingMadeOfCloth objTROZO "trozo" ALDEA_SAJONA
with
	name 'TROZO',
	description [;
        print "Es un poco de lo que antes era tu capa.";
        ThingMadeOfCloth.description();
		"";
    ],
has   ;

! Gramática --------------------------------------------------------------------
[ ayudaSub;
    print "^Las órdenes siguientes son básicas y pueden encontrarse
      en casi cualquier aventura conversacional. El jugador
      puede tratar siempre de hacer otras acciones.^^"
    ;
    s_fixed();
    print "^
     ayuda                 -   Esta ayuda.^
     (n)orte, (s)ur, (e)ste, (o)este, arriba, abajo
                           -   Moverse según los puntos cardinales.^
     ex, examinar x        -   Da una descripción de x.^
     examinarme, xme       -   Información sobre ti y sobre tu misión.^
     hablar con y          -   Permite comunicarse con y, si está presente.^
     coge x, deja x        -   x pasa a ser o deja de ser llevado.^
     i, inventario         -   Da una lista de los objetos llevados.^
     Dar x a y             -   Ofrece el objeto x al personaje y.^
     ^^"
    ;
    s_normal();
    print (s_underline) "Por Baltasar, el Arquero.", (s_normal)
    "^^
      Mándame tus comentarios a: baltasarq@@64yahoo.es
      ^^
      Tú eres ", (s_underline) player.short_name,
      ", oficial britano, soldado y amigo del Rey Uther Pendragón, seńor de Locres.
     ^";
    <<Examine player>>;
];

[ searchSub;
    "No conseguirás nada así.^";
];

[ gritarSub;
    if ( location ofclass Cueva )
            "Gritas con todas tus fuerzas. El eco devuelve el sonido todo a lo largo
             de la caverna.";
    else    "Gritas, pero te sientes un poco estúpido.";
];

[ sharpenSub;
    "No conseguirás nada así.";
];

[ untieSub;
    "No lograrás nada así.";
];

Verb meta 'pista' 'pistas' 'help' 'ayuda'
    * -> ayuda
;

verb 'bucea' = 'nada';

Extend 'nada' last
    * 'en' noun -> swim
    * 'a//'/'al'/'hacia' noun -> swim
;

Extend 'busca' last
    * -> Search
    * topic -> Search
;

Extend 'grita' replace
    * -> gritar
;

Verb 'arregla'
    * noun 'con' noun -> Tie reverse
;

Verb 'refuerza' = 'arregla';
VerboIrregular "reforzar" with imperativo 'refuerza';

Verb 'repara' = 'arregla';

Verb 'desata'
    * noun -> Untie
    * noun 'de' noun -> Untie
;

Verb 'afila'
    * noun -> Sharpen
    * noun 'con' noun -> Sharpen
;

Extend 'ataca' last
    * noun 'con'/'usando' noun -> Attack
;

Extend 'golpea' last
    * noun 'con'/'usando' noun -> Attack
;

Extend 'empuja' last
    * noun 'con'/'usando' noun -> Push
;

Verb 'aceita'
    * noun                  -> Rub
    * noun 'con'/'de' held  -> Rub
;

verb 'engrasa' 'unta' 'exprime' = 'aceita';
