! [loc#40]
Room INTERIOR_DE_LA_CASCADA "Interior de la cascada"
with
	description [;
        print "^^El interior de la cascada es musgoso y rocoso, con la cortina de agua tras de ti. El sitio es estrecho sin duda, y el nivel del agua ha crecido un poco.^";
		rtrue;
	],
	e_to [;
        <<Swim>>;
    ],
;

SceneryThing objCascada "cascada"
with
    found_in [;
        if ( location == INTERIOR_DE_LA_CASCADA or CASCADA )
                rtrue;
        else    rfalse;
    ],
    name 'cascada' 'cortina' 'agua' 'poza',
    description [;
        "La impenetrable cortina de agua cae pesadamente
         sobre la cristalina superficie de
         la pequeńa poza, rompiendo el agua en mil ondas que se estrellan
         contra las paredes de fría y húmeda roca.";
    ],
    react_before [ locDest;
        Swim:
            if ( children( player ) > 1
              || ~~( child( player ) ofclass ThingMadeOfCloth ) )
            {
                novelar( "Ulfius trató de sumergirse y bucear por debajo
                          de la cortina de agua, sin embargo, el peso de todas
                          sus pertenencias le incomodaba e impedía nadar
                          con libertad, por lo que volvió atrás."
                );

                rtrue;
            }

            if ( location == INTERIOR_DE_LA_CASCADA )
                    locDest = CASCADA;
            else    locDest = INTERIOR_DE_LA_CASCADA;

            novelar( "Ulfius se sumergió justo antes de la cortina de agua,
                      pasando por debajo del blanco y estruendoso gorgoteo."
            );

            playerTo( locDest, 2 );
            rtrue;
    ],
has female;

