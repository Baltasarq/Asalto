;

class Room
class Cueva
;

class CuevaConLuz
class Cueva
has light;

class Exterior
has light;

class Thing;

class ThingMadeOfCloth
class Thing
private
    aceitoso false,
with
    estaAceitoso [;
        return self.aceitoso;
    ],
    ponAceitoso [;
        self.aceitoso = true;
    ],
    description [;
        if ( children( self ) > 0 ) {
            print "^Atado a ", (the) self, ", tienes: ";
            listChildrenOf( self );
        }
    ],
    before [;
        Tie:
            if ( second == puentePodrido ) {
                return puentePodrido.arreglarCordaje();
            }
            else
            if  ( second == objESPADA ) {
                return objEspada.tieObject( self );
            }
        Untie:
            if ( second == Nothing or objEspada ) {
                if ( ~~( isReachable( objESPADA ) ) ) {
                    player.think( "ˇPero si no está aquí!" );
                }

                second = objESPADA;

                if ( self notin objEspada ) {
                    print "No lograrás nada así.";
                    rtrue;
                }

                move self to player;
                "Desatas ", (the) self, " de ", (the) second, ".";
            }
    ],
;

class SceneryThing
class Thing
has scenery;

[ initCapa;
    move objCAPA to player;

	move objTROZO to limbo;
	move objHILO to limbo;
	move objHARAPO to limbo;
];

[ destroyCapa;
    move objCAPA to limbo;

	move objTROZO to player;
	move objHILO to player;
	move objHARAPO to player;
];

[ scroll;
    s_emph(); wait( "..." ); s_normal();
    print "^^";
];

[ novelar text;
    print (s_fixed) text, "^";
    scroll();
];

[ hazInitIntro;
    clearMainWindow();
    viewImageCenter( picEspada );
    print (s_emph) "^Asalto y Castigo^";
    print (s_underline) "... o el despertar de Ulfius.^^";
    scroll();
];

[ hazIntro;
    hazInitIntro();

    novelar( "^^Guardando la espada en su funda, y volviendo a montar a caballo,
              Ulfius dió las órdenes para reagrupar la partida en la colina."
    );

    player.think( "El rey Uther estaba equivocado. No había tropas sajonas esperando." );

    novelar( "El general observó con desagrado las cenizas, los cadáveres.
           Lejos, en alguna parte, un nińo llora.
           Los restos carbonizados de las casas exhalan su último aliento
           hacia el cielo, pero antes se encuentra con la niebla, creando un
           ambiente oclusivo y extrańo.
    " );

    player.think( "No hubo honor, honra o valía en esta batalla." );

    novelar( "Con una sensación mezcla de repulsa y desagrado, Ulfius invocó a su
              primer oficial.^"
    );

    soldados.changeToOfficer();
    soldados.say( "żSire?" );
    player.say( "Detengan el saqueo. Nos vamos. Volvemos a Westmorland." );
    soldados.say( "Sire, muchos esperaban obtener ganancias..." );
    player.say( "żSaqueando?żRobando a los muertos?" );
    soldados.say( "..." );
    player.say( "Aquí no hay nada. Tendrán que conformarse con la paga." );
    soldados.say( "Sí, sire." );
    soldados.restoreSoldiers();

    novelar( "El britano recordó entonces la sala de mapas,
              la discusión con el Rey, su sospecha de la
              presencia de tropas en esta zona, y el regio objetivo de realizar
              una expedición de castigo contra esta aldea fronteriza."
    );

    player.think( "En realidad, Uther parecía más preocupado por algún plan
                   contra Cornualles que en esta expedición. Me alegro de haberme
                   equivocado, y que no hubiera tropas, finalmente."
    );

    novelar( "Ulfius espoleó su caballo hasta quedar a medio camino entre la colina
              donde había comenzado el ataque, y la aldea, esperando a que sus
              tropas se reunieran con él."
    );
];

[ hazPresentacion;
    hazInitIntro();

    print "żDeseas cargar una posición guardada anteriormente? (Sí/No): ";

    if ( YesOrNo() ) {
        <restore>;
    }

     print "żDeseas ver la introducción? (Sí/No): ";

    if ( YesOrNo() ) {
        hazIntro();
    }

    clearMainWindow();
];

[ initialise;
    ! Conf.
    lookmode = 2;           ! Siempre redescribir

    ! Personajes
    changePlayer( jugador );
	location = ALDEA_SAJONA;
    jugador.prepareAllCharacters();
    move pnjAmbrosio to REFUGIO_DE_AMBROSIO;
    move pnjJEFE_DE_REFUGIADOS to ALBERGUE_DE_REFUGIADOS;
    move pnjREFUGIADOS to ALBERGUE_DE_REFUGIADOS;

	! Objetos de inventario
	move objESPADA to player;
    move objARMADURA to player;
    initCapa();

	! Grfs & Snds ---
	initializeSMW( 50 );
    hazPresentacion();

 !   location = SALIDA_DE_LA_CUEVA; move objAntorcha to player; give objAntorcha light; move pnjAmbrosio to HOGAR_DE_AMBROSIO; !pnjAmbrosio.status = 3;
];

[ newRoom;
    if ( pnjAmbrosio.getStatus() > 2) {
        if( location == HOGAR_DE_AMBROSIO or CRUCE_DE_PASAJES or SALIDA_DE_LA_CUEVA )
        {
            if ( pnjAmbrosio in HOGAR_DE_AMBROSIO ) {
                novelar( "Ambrosio se apresuró desde las profundidades
                          de la cueva, al oeste."
                );
            }

            move pnjAmbrosio to location;
            novelar( "El anciano, esperanzado, seguía los pasos del general." );
        }
        else
        if ( location == LAGO_INTERIOR
          && parent( self ) ~= HOGAR_DE_AMBROSIO )
        {
            novelar( "Caminando tras Ulfius,
                       el anciano pareció repentinamente nervioso y preocupado..." );
            pnjAmbrosio.say( "Mi buen Ulfius... prefiero aguardaros atrás, en mi hogar...
                       Por favor, no tardéis demasiado... he esperado tanto
                       tiempo salir de aquí... os ruego que volváis pronto."
            );
            move pnjAmbrosio to HOGAR_DE_AMBROSIO;
        }
    }
];

! ================= Rooms ===============

! [loc#1]
Exterior ALDEA_SAJONA "Aldea Sajona"
with
	description [;
		drawImage( picAldeaSajona, SMW_POS_CENTER );
	        print "^No ha quedado nada en pie, ni piedra sobre piedra. Los rescoldos
	                de lo que antes fue una aldea de pastores sajones humean hacia un cielo
	                agrisado por el fuego. El entorno es desolador, el futuro de los
	                supervivientes, ahora seguramente escondidos en el bosque, incierto.^^";
		rtrue;
	],
	s_to SOBRE_LA_COLINA,
;

SceneryThing ALDEA "Aldea sajona" ALDEA_SAJONA
with
    name_f 'aldea' 'sajona' 'villa',
    name_m 'pueblo',
    before [;
        examine:
            <<Look>>;
        default:
            "No. No resta sino retirarse.";
    ],
has female;

! [loc#28]
CuevaConLuz ALBERGUE_DE_REFUGIADOS "Albergue de refugiados"
private
    pasoBloqueado true,
with
    estaPasoBloqueado [;
        return self.pasoBloqueado;
    ],
    bloqueaPaso [;
        self.pasoBloqueado = true;
    ],
    desbloqueaPaso [;
        self.pasoBloqueado = false;
        pnjRefugiados.desbloquear();
        rtrue;
    ],
	description [;
        print "^^Una amplia estancia, iluminada por varias antorchas,
                sirve de refugio a hombres de distintas razas.
                Las banderas, con los dragones rojo y blanco,
                se exhiben en una de las paredes. Familias enteras,
                nińos sucios y llorosos; gente que se apila en camastros de paja,
                para dormir un efímero descanso. Sin embargo, la ilusión y la
                alegría se aprecian además; si bien escasea.
                ^Un hombre de larga barba blanca, portando una larga vara,
                es la cabeza visible de esta gente.^";
		rtrue;
	],
	n_to LABERINTO6,
	e_to [;
        if ( self.estaPasoBloqueado() ) {
            "Los refugiados bloquean tu paso, su gesto no es violento, pero su
             actitud es amenazante.";
        }

        print "Pasas vigilante entre los refugiados...^";
        playerTo( ESPIRAL, 2 );
        rtrue;
    ],
	w_to REFECTORIO_DE_REFUGIADOS,

;

! [loc#6]
Exterior BOSQUE "Bosque"
with
	description [;
        drawImage( picBosqueNiebla, SMW_POS_CENTER );
        print "^El frondoso bosque hace que jirones de la ahora fina niebla se enzarcen en sus ramas y arbustos. El sol es cada vez más visible entre la bruma, a medida que se desciende, y viceversa al ascender.^La estrecha senda serpentea entre raices, discurriendo del luminoso este a un difuminado oeste.^^";
		rtrue;
	],
	e_to LINDE_DEL_BOSQUE,
	w_to PASO_DEL_PERRO,

;

! [loc#48]
Exterior BOSQUE_A_LA_ENTRADA "Bosque a la entrada"
with
	description [;
        player.setOutOfCave();
        drawImage( picSalidaCueva, SMW_POS_CENTER );
        print "^^Apenas se puede reconocer la entrada de la caverna, al norte.
                Te encuentras en un lugar terríblemente húmedo, en contraste con las
                áridas paredes del Paso del Perro. Es obvio que no
                esto no es la sierra, donde te introdujiste en este pasillo descendente
                natural hasta el valle.
                ^El sendero sale al bosque hacia el oeste.^";
		rtrue;
	],
	w_to SENDERO_DEL_BOSQUE,
    cant_go [;
        player.think( "No pienso ir a ningún otro sitio que no sea Westmorland." );
    ],

;

! [loc#3]
Exterior CAMINO_ENTRE_COLINAS "Camino entre colinas"
with
	description [;
        drawImage( picBosquePrincipio, SMW_POS_CENTER );
        print "^El camino avanza por el valle, desde la parte alta, al este,
                a una zona harto boscosa, al oeste. Al fondo, se adivinan
                las estribaciones de la sierra. El terreno es árido,
                y la vegetación, aunque abundante, se enraíza con fuerza sobre la
                tierra desolada. Los fuertes vientos han hecho de la vida aquí
                un reto para todas las especies.^^";
		rtrue;
	],
	e_to SOBRE_LA_COLINA,
	w_to CRUCE_DE_CAMINOS,

;

! [loc#50]
Exterior CAMINO_NORTE "Camino norte"
with
	description [;
        drawImage( picWestmorland, SMW_POS_CENTER );
        print "^^El camino norte de Westmorland se interna hacia el bosque, al norte, y a Westmorland, al sur.^";
		rtrue;
	],
    n_to [;
        player.think( "No tengo nada que hacer al norte de Westmorland.
                       No conseguiría nada, en cualquier caso, en mi estado."
        );
    ],
	s_to WESTMORLAND,
	e_to SENDERO_DEL_BOSQUE,

;

! [loc#38]
Room CANAL_DE_AGUA "Canal de agua"
with
	description [;
        print "^^El agua descendiende con renovadas fuerzas y gran estruendo,
                dejando un estrecho paso elevado lateral para subir,
                esquivando estalactitas. La piedra húmeda resbala, es necesario
                moverse con el mayor cuidado posible.^"
        ;
		rtrue;
	],
	e_to REMANSO,
	w_to CASCADA,
;

! [loc#39]
Room CASCADA "Cascada"
with
