! [loc#7]
Exterior PASO_DEL_PERRO "Paso del perro"
with
	description [;
        drawImage( picPasoDelPerro, SMW_POS_CENTER );
        print "^Abruptamente el bosque desaparece, despejándose hacia un camino rocoso, entre paredes de piedra. La senda, seca y polvorienta, serpentea hacia el sur, hasta donde alcanza la vista. El contraste entre el bosque y el paso es asombroso, pareciendo que el ávido polvo come terreno al primero rocoso bosque, más tarde fértil y húmedo.
        ^Se trata del estrecho e inquietante desfiladero del Paso del Perro, que tuerce de sur a este.
        ^La intranquilidad sacude la mente cuando se observan las altas paredes, temiendo
        siempre la emboscada del odiado enemigo sajón.^^";
		rtrue;
	],
	s_to ENTRADA_A_LA_CUEVA,
	e_to BOSQUE,

;

