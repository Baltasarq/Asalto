! [loc#4]
Exterior CRUCE_DE_CAMINOS "Cruce de caminos"
with
	description [;
        print "^La senda se bifurca hacia el norte,
                rodeando las estribaciones de la sierra que cierra el
                valle al oeste, con el paso del perro como ruta entre ellas.
                El camino del norte da un rodeo por el bosque, mientras que el
                del oeste accede directamente al paso del perro.^^";
		rtrue;
	],
	n_to LINDE_DEL_BOSQUE,
	e_to CAMINO_ENTRE_COLINAS,
	w_to DERRUMBE,

;

! [loc#45]
Room CRUCE_DE_PASAJES "Cruce de pasajes"
with
	description [;
        print "^^Un cruce de estrechos pasajes permite ir al oeste,
                 al este y al sur. La luz parece inundar el pasaje al sur, mientras desaparece
                 completamente al oeste, y es apenas perceptible al este. Una fuerte
                 corriente de aire parece querer arrastrarlo todo hacia el sur.^";
		rtrue;
	],
	s_to [;
        playerTo( SALIDA_DE_LA_CUEVA, 2 );
        rtrue;
    ],
	e_to LAGO_INTERIOR,
	w_to HOGAR_DE_AMBROSIO,
;

! [loc#9]
Exterior DERRUMBE "Derrumbe"
with
	description [;
        print "^El camino desciende entre desnudas paredes desde el paso del perro,
                hacia el oeste, a los valles, al este.
                Un gran desmoronamiento, sin embargo, de rocas bloquea
                el camino al paso. Resulta imposible pasar.^^";
		rtrue;
	],
	e_to CRUCE_DE_CAMINOS,

;

! [loc#8]
Exterior ENTRADA_A_LA_CUEVA "Campo del paso del Perro"
with
    bloqueado [;
        player.think( "ˇMaldita sea!" );
        "Resulta imposible. Las tropas sajones cubren las salidas al norte y al sureste.";
    ],
	description [;
        if ( self hasnt visited ) {
            soldados.initial = "Tus tropas luchan con denuedo contra los sajones.
                               Los oficales organizan la lucha."
            ;
            sajones.activate();

            novelar( "Repentinamente, el general britano supo que algo va mal.
                      En rápida sucesión, jinetes aparecieron por delante y por
                      detrás de la partida. Estaban atrapados."
            );

            player.say( "ˇBritanoooos!ˇA las armas!ˇFormad una defensa!" );

            novelar( "Las tropas britanas se replegaron sobre el terreno con presteza, listos
                   para presentar batalla."
            );
        }

        print "^El paso entre el desfiladero sigue de norte a sureste.
                Las paredes de desnuda roca abren aquí un angosto, aunque espacioso
                en comparación con el resto del paso, campo de unas cincuenta yardas
                de ancho. El ensanche se extiende por unas doscientas yardas. Más allá,
                el resto del desfiladero se antoja envuelto en sombras.
                ^^";
		rtrue;
	],
    in_to  [;  <<Enter entradaCueva>>; ],
	s_to   [;  <<Enter entradaCueva>>; ],
    se_to  [; return self.bloqueado(); ],
    n_to   [; return self.bloqueado(); ],
;

Character sajones "tropas sajonas" ENTRADA_A_LA_CUEVA
private
    activated false,
with
    isActivated [;
        return self.activated;
    ],
    activate [;
        self.activated = true;
        startTimer( self, 15 );
    ],
    deactivate [;
        self.activated = false;
        stopTimer( self );
    ],
    short_name "tropas sajonas",
    name_f 'partida' 'sajona',
    name_fp 'tropas' 'sajonas',
    name_mp 'soldados' 'sajones',
    time_left 15,
    time_out [;
        if ( location == ENTRADA_A_LA_CUEVA ) {
            print "Los sajones acaban con lo que queda de tus tropas, y te rodean.^";
        }

        print "Un oficial sajón aparece, protegido por su guardia de corps, y
               sonríe ampliamente.";

        sajones.short_name = "Oficial sajón";
        give sajones proper;

        sajones.say( "ˇPero si no es otro que Ulfius, el gran oficial britano!" );
        sajones.say( "Ahora, nuestra ganancia es doble." );
        novelar( "El oficial desenvainó su espada, Ulfius bien conocedor del final." );
        sajones.say( "El ~Gran Uther~ se alegrará de recibir vuestra cabeza, ~sire~." );
        deadflag = 1;
    ],
has female pluralname;

SceneryThing paredesDesfiladero "paredes del desfiladero"
with
    found_in [;
        if ( location == ENTRADA_A_LA_CUEVA or PASO_DEL_PERRO )
                rtrue;
        else    rfalse;
    ],
    name_fp 'paredes',
    name_f  'pared',
    name_m  'desfiladero' 'paso' 'pasaje',
    description [;
        "Las paredes del desfiladero son lisas e imponentes, antojándose
         altas hasta donde alcanza la vista. Sin embargo, la pared más cercana se
         hace menos lisa a medida que se desciende la mirada hacia el suelo, hasta
         romperse en una serie de grandes mandíbulas que rodean la negrura en la
         base de la roca.
         ^Puedes distinguir una abertura en la pared más cercana.^";
    ],
;

SceneryThing entradaCueva "entrada a la cueva" ENTRADA_A_LA_CUEVA
with
    name_f  'entrada' 'cueva' 'caverna' 'abertura' 'rampa' 'depresion' 'oquedad' 'gruta',
    name_fp 'piedras',
    name_mp 'cascotes',
    description [;
        drawImage( picEntradaCueva, SMW_POS_CENTER );
        "La entrada a una cueva se abre al sur en la pared de roca. Aunque queda
        dismulada por una depresión del terreno, su tamańo es notorio, debido, en contraste,
        a la estrechez del paso del perro. Cascotes y piedras de todos los tamańos
        se agolpan en la rampa de tierra que conduce hasta ella. De su interior
        no se adivina gran cosa, puesto que, aún pese a la gran luz, esta es
        incapaz de vencer más que unas pocas yardas la reinante oscuridad en la oquedad.
        ^Aún a pesar de la situación, es difícil pensar en ese lugar como una posible
        salida, si bien probablemente la única.";
    ],
    before [;
        Enter:
            print (s_fixed) "Corres hacia la cueva, tratando de salvar tu vida.^";
            playerTo( GRUTA_DE_ENTRADA, 2 );
            rtrue;
    ],
has female;

! [loc#29]
Room ESPIRAL "Espiral"
with
	description [;
        print "^^Una espiral de piedra, cual escalera de caracol gigante,
               se enmarca en una chimenea natural de gran altura, que no permite
               otras posibilidades que ascender o descender... La espiral ha
               sido construída por el hombre, sin duda, aunque largo tiempo atrás.
               Su perfil irregular y cantera basta atestigua sus orígenes artesanos,
               sin desmerecer el mérito de tan magna obra.^";
		rtrue;
	],
	w_to ALBERGUE_DE_REFUGIADOS,
	d_to INICIO_DE_LA_ESPIRAL,
;

! [loc#17]
CuevaConLuz ESTALACTITAS "Estalactitas"
with
	description [;
        print "^Muchas estalactitas se agrupan encima de tu cabeza,
                y se hacen de menor tallaje, cual arcos de sendos pasajes,
                hacia el este y sur. La belleza es inenarrable, si bien no deja
                de ser peligroso levantar mucho la cabeza sin mirar antes.^^"
        ;
		rtrue;
	],
	n_to PASAJE_ARENOSO,
	s_to LABERINTO1,
	e_to PUENTE_DE_PIEDRA,
;

SceneryThing objEstalactitas "Estalactitas" ESTALACTITAS
with
    name_fp 'estacas' 'estalactitas',
    name_f 'estaca' 'estalactita',
    description "Largas y afiladas, cuelgan desde el techo como estacas mortalmente afiladas.",
    before [;
        Take:
            "Tratas de desencajar una, pero su proximidad a las demás, sus afiladas
             puntas, y la solidez que proporcionan los ańos de formación, lo impiden.";
    ],
has female pluralname;

! [loc#30]
Room ESTRECHO_PASAJE "Estrecho pasaje"
with
	description [;
        drawImage( picPasaje, SMW_POS_CENTER );
        print "^^La caverna se estrecha ahora, en un angosto y húmedo túnel.
                 Parece un pasaje para una sola persona, excavado en la roca,
                 aunque no por la mano del hombre, sino por la fuerza
