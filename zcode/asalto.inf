! [loc#11]
CuevaConLuz GRAN_LAGO "Gran lago"
with
    desc "^Emergiendo del pasaje en una gran estancia, un lago de profundas
                e iridiscentes aguas se abre ocupando más de la mitad de la galería.
                La luz exterior, que entra por algún tipo de hueco en el centro de la
                caverna, crea caprichosos reflejos de asombrosa tonalidad azul.
               ^El agua es asombrosamente cirstalina, clara, limpia, y profunda.
               ^No hay más salida que el este, el pasaje de entrada por el que
               te introdujiste en la caverna, por el que se adivina una luz más
               blanca y clara que el entorno azulado de la sala.^",
	description [;
        drawImage( picLagoEntradaCueva, SMW_POS_CENTER  );
        print self.desc;
        if ( self hasnt visited ) {
            print (s_underline)
                "^No puedes evitar dedicar un tiempo, que no puedes precisar, ajeno
                   a tu entorno, admirando la belleza del lugar.^"
            ;
        }

        print "^";
        rtrue;
	],
	e_to GRUTA_DE_ENTRADA,
;

SceneryThing LAGO "lago" GRAN_LAGO
with
    name 'gran' 'lago',
    name_f 'agua' 'cristalina',
    name_fp 'aguas' 'cristalinas',

    description [;
        <<look>>;
    ],
    before [;
        Swim:
            <<Swim>>;
        Enter:
            <<Swim>>;
    ],
    react_before [;
        GoIn:
            <<Swim>>;
        Swim:
            novelar( "Ulfius, sin perder más tiempo, se introdujo en las frías aguas." );

            novelar( "Sin embargo, se sumergió más rápido de lo que pensaba, y cayó
                   hacia el fondo sin poder remediarlo, entre desesperados aspamientos."
            );

            novelar( "Supo entonces que estaba atrapado." );

            playerTo( FONDO_DEL_LAGO, 2 );
            rtrue;
    ],
;

CuevaConLuz FONDO_DEL_LAGO "Fondo del lago"
private
    numVisited 0,
with
    time_left 10,
    time_out [;
        player.think( "ˇDios... santo..." );
        novelar( "Incapaz de sostener la situación por más tiempo, Ulfius se
               dejó llevar por sus reflejos, haciéndole tragar agua,
               en un reflejo inconsciente  y desesperado por respirar."
        );

        novelar( "Perdió el control de tu cuerpo, su vista se le desvaneció.^" );

        deadflag = 1;
    ],
    description [;
        if ( self hasnt visited ) {
            sajones.deactivate();
            startTimer( self, 10 );
        }

        self.numVisited++;
        print "El fondo del lago se torna oscuro con la profundidad,
               en contraste con las claras y luminosas aguas más arriba.^"
        ;

        if ( self.numVisited > 3 ) {
            print (s_underline) "Fijándote bien, hay otra fuente luminosa al oeste.^";
        }

        rtrue;
    ],
    each_turn [;
        if ( self.time_left == 6 ) {
            print "Empiezas a echar en falta el aire...^";
        }
        else
        if ( self.time_left == 3 ) {
            print "Empiezas a asustarte...^";
            player.think( "ˇDios santo! ˇVoy a ahogarme!" );
        }
    ],
    isArmaduraOnPlayer [;
        if ( objARMADURA in player ) {
            print "No puedes apenas moverte, cada avance es efímero y te
                   deposita de nuevo en el fondo.^"
            ;
            rtrue;
        }
        rfalse;
    ],
    cant_go [;
        if ( ~~( self.isArmaduraOnPlayer() ) ) {
            print "No sabes hacia donde nadar... está tan oscuro.^";
        }
    ],
    w_to [;
        if ( self.numvisited <= 3 ) {
            <<Go n_obj>>;
        }

        if ( self.isArmaduraOnPlayer() ) {
            rtrue;
        }

        stopTimer( self );
        print "Nadas con todas tus fuerzas hacia la luz...^";
        playerTo( SALIDA_DEL_PASO_SECRETO, 2 );
        rtrue;
    ],
;

SceneryThing LAGO2 "fondo del lago" FONDO_DEL_LAGO
with
    name_m 'gran' 'fondo' 'lago',
    name_f 'agua' 'cristalina',
    name_fp 'aguas' 'cristalinas',
    description [;
        <<look>>;
    ],
    buscaSalida [;
        print (s_underline) "Buscas una posible salida con todas tus fuerzas...^";
        <<Look>>;
    ],
    before [;
        Search, Consult:
            return self.buscaSalida();
        Swim:
            <<Swim>>;
    ],
    react_before [;
        Search:
            return self.buscaSalida();
        Swim:
            if ( noun == Nothing ) {
                if ( ~~( FONDO_DEL_LAGO.isArmaduraOnPlayer() ) ) {
                    print "No sabes muy bien hacia dónde nadar... está tan oscuro.^";
                    rtrue;
                }
            }

            if ( noun ~= n_obj or w_obj or e_obj or s_obj ) {
                print "No puedes nadar hacia allí.^";
                rtrue;
            }

            <<Go noun>>;
    ],
;

! [loc#10]
CuevaConLuz GRUTA_DE_ENTRADA "Gruta de entrada"
with
	description [;
        print "^El pasaje se adentra en el corazón de la montańa, si bien se antoja cada vez
                más y más húmedo. Las paredes están cubiertas de musgo, y el suelo se encuentra
                salpicado de charcos aquí y allá, cerca de donde la vista se pierde en la oscuridad
                de las entrańas de esta cueva.
            ^El estrecho paso se adentra, torciendo hacia el oeste, desde la boca, al norte.^
        ^";
		rtrue;
	],
	n_to ENTRADA_A_LA_CUEVA,
	w_to GRAN_LAGO,

;
