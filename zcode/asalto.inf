with
	name 'DERRUMBE',
	description "Muchas, inalcanzables rocas, apiladas una sobre otra."
has   ;

Thing objESMERALDA "esmeralda" INTERIOR_DE_LA_CASCADA
with
	name 'ESMERALDA',
	description "Es, símplemente, preciosa.",
    before [;
        Tie:
            if ( second ofclass ThingMadeOfCloth ) {
                move self to second;
                print "Atas con cuidado ", (the) self, " a ", (the) second,
                      ", de manera que quede fuertemente asegurada.^"
                ;
                rtrue;
            }
        UnTie:
            if ( second == Nothing ) {
                second = parent( self );
            }

            if ( self notin player ) {
                print "Desatas ", (the) self, " de ", (the) second, ", recuperándola.^";
                move self to player;
                rtrue;
            }
    ],
has female;

Thing objESPADA "espada" ALDEA_SAJONA
with
	name 'ESPADA',
    tieObject [ x;
        if ( x == objCAPA ) {
            player.think( "La capa es demasiado grande como para atarla a la espada." );
            rtrue;
        }

        if ( children( self ) == 2 ) {
            player.think( "Ya no hay sitio en la espada donde atar más cosas." );
            rtrue;
        }

        give x ~worn;
        move x to self;
        print "Atas ", (the) x, " a ", (the) self, ".^";
        rtrue;
    ],
	description [;
        print "Legado de tu padre, fiel herramienta en mil batallas.";


        if ( children( self ) > 0 ) {
            print " Atada a ella, ves: ";
            listChildrenOf( self );
        }

        print "^";
        rtrue;
    ],
    before [;
        Drop:
            if ( location ofclass Cueva )
                    rfalse;
            else    "No puedes hacerlo. Es todo lo que te queda de tu padre.";
    ],
has female transparent ;

