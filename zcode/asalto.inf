        <<look>>;
    ],
;

! [loc#15]
CuevaConLuz PUENTE_SEMIPODRIDO "Puente semipodrido"
with
	description [;
        print "^La sala se abre en semioscuridad a un puente cubierto de podredumbre sobre el lecho de un canal, de este a oeste. En la parte oeste, se distingue un curioso montículo.^^";
		rtrue;
	],
	e_to SALIDA_DEL_PASO_SECRETO,
	w_to [;
        if ( puentePodrido.atraviesalo() ) {
            playerTo( RECODO_DE_LA_CUEVA, 2 );
            rtrue;
        }
        rtrue;
    ],
;

SceneryThing monticuloDeFangoFalso "montículo de fango" PUENTE_SEMIPODRIDO
with
    name 'monticulo' 'fango',
    description "En el otro lado del puente, ves una curiosa formación de fango...",
    before [;
        Examine:
            rfalse;
        default:
            "Está demasiado lejos.";
    ],
    react_before [;
        ThrowAt:
            if ( second == monticuloDeFangoFalso ) {
                if ( noun ofclass ThingMadeOfCloth ) {
                    player.think( "Es demasiado ligero; no llegaría al otro lado." );
                    rtrue;
                }

                move noun to monticuloDeFango;
                print (The) noun, " vuela, girando sobre sí, hasta el montículo.^";
            } else {
                player.think( "Tengo miedo de perderlo. Tengo que buscar un lugar
                               donde no se escurra hasta la corriente, de ninguna
                               forma." );
            }

            rtrue;
    ],
;

SceneryThing puentePodrido "puente en mal estado" PUENTE_SEMIPODRIDO
private
    cordajeArreglado false,
with
    found_in [;
        if ( location == PUENTE_SEMIPODRIDO
          || location == RECODO_DE_LA_CUEVA )
        {
            rtrue;
        }
        rfalse;
    ],
    arreglarCordaje [;
        if ( location ~= PUENTE_SEMIPODRIDO ) {
            "El cordaje de este lado del puente está perfectamente.";
        }

        if ( ~~( isReachable( noun ) ) ) {
            "Necesitarías atar algo para asegurar mejor el cordaje.";
        }

        if ( self.cordajeArreglado ) {
            player.think( "Ya he arreglado el cordaje, no es necesario hacer más" );
        }

        self.cordajeArreglado = true;
        move noun to limbo;

        "Utilizando un resto de lo que antes era tu capa, aseguras mejor lo
         que queda del cordaje que ayuda a mantener el puente en su sitio.";
    ],
    name_m 'puente' 'paso' 'cordaje' 'amarre',
    name_f 'cuerda',
    description [;
        print "El estado del puente es lamentable,
               temiendo que se desplome en cualquier momento.";

        if ( location == PUENTE_SEMIPODRIDO
          && ~~self.cordajeArreglado )
        {
            print " El cordaje que asegura el puente a este lado de la orilla
                   está en un estado deplorable.";
        }

        "^";
    ],
    atraviesalo [;
        if ( children( player ) > 0
          || ~~self.cordajeArreglado )
        {
            novelar( "Ulfius avanzó unos pasos sobre el puente, pero este
                      crujía peligrosamente..."
            );

            player.think( "Esto no parece una buena idea, al menos por ahora." );
            rfalse;
        }

        novelar( "El general britano avanzó cuidadosamente por el puente." );
        novelar( "Este se bamboleaba, peligrosamente, a ambos lados." );
        novelar( "Sin embargo, aguantó milagrosamente su peso, y se encontró al otro lado." );
        rtrue;
    ],
    before [ dir;
        Enter:
            if ( location == PUENTE_SEMIPODRIDO )
                    dir = w_obj;
            else    dir = e_obj;

            <<Go dir>>;
        JumpOver:
            player.think( "El puente es demasiado largo como para saltarlo.
                           Demasiado incluso como para atravesarlo en varios saltos."
            );
            rtrue;
    ],
;

